#!/usr/bin/env zsh
# zsh functions
# Auther: CrtlUserUnknown
#
# to find the zsh config file look at ~/.zshrc
# to find the aliases look at ~/.config/zsh/.aliases

# --- functions:devUx ---
function commands() {
    if [[ "$1" == "costum" ]]; then
        echo "--- Aliases ---"
        echo "cls        clear the terminal"
        echo "ls         eza with color"
        echo "lla        eza all files with icons"
        echo "ll         eza list with icons"
        echo "reload     source ~/.zshrc"
        echo "open       open current directory"
        echo "y          yazi"
        echo "py         python3"
        echo "ipy        ipython3"
        echo "swiftinit  swift package init"
        echo "sps        swift package show-dependencies"
        echo "spt        swift package test"
        echo "jv         java"
        echo "jc         javac"
        echo "rn         rustc"
        echo "cr         cargo run"
        echo "mux        tmux"
        echo "b          btop"
        echo "f          fzf"
        echo ""
        echo "--- Functions ---"
        echo "commands   list commands or custom aliases/functions"
        echo "config     edit zsh, tmux, ghostty, or alias configs"
        echo "create     scaffold a new project (Swift, Java, Rust, Crystal, Git)"
        echo "attach     attach to a tmux session via fzf"
        echo "mux-session  create or attach to a named tmux session"
        echo "duplicate  duplicate a file or folder"
        echo "download   download a file using curl or wget"
    else
        echo $PATH | tr ':' '\n' | while read dir; do
            ls "$dir" 2>/dev/null
        done | sort -u | grep -v '/' | grep -v '@' | column -c $(tput cols)
        echo "\nTip: run 'commands custom' to see your custom aliases/functions"
    fi
}

function config() {
    if [[ -z "$1" ]]; then
        echo "Select configuration to edit:"
        select option in "Terminal/ZSH" "Tmux" "Ghostty" "Aliases" "Cancel"; do
            case "$option" in
                "Terminal/ZSH") ${EDITOR:-nvim} ~/development/dots/src/zsh/; break;;
                "Tmux") ${EDITOR:-nvim} ~/development/dots/src/tmux/tmux.conf; break;;
                "Ghostty") ${EDITOR:-nvim} ~/development/dots/src/ghostty/config; break;;
                "Aliases") ${EDITOR:-nvim} ~/development/dots/src/zsh/zsh/.aliases; break;;
                "Cancel") return 0;;
            esac
        done
    else
        case "$1" in
            terminal|zsh) ${EDITOR:-nvim} ~/development/dots/src/zsh/;;
            tmux|mux) ${EDITOR:-nvim} ~/development/dots/src/tmux/tmux.conf;;
            ghostty|ghost) ${EDITOR:-nvim} ~/development/dots/src/ghostty/config;;
            alias|aliases) ${EDITOR:-nvim} ~/development/dots/src/zsh/zsh/.aliases;;
            *) echo "Unknown config type: $1"; return 1;;
        esac
    fi
}

# --- functions:tmux-session ---
# Creates a named tmux session with standard windows, or attaches if it already exists.
# Usage: mux-session [session-name]  (defaults to current directory name)
function mux-session() {
    if ! command -v tmux &>/dev/null; then
        echo "Error: tmux is not installed"
        return 1
    fi

    local session_name="${1:-$(basename "$PWD")}"
    local project_path="$PWD"

    if ! tmux has-session -t "$session_name" 2>/dev/null; then
        # Create session and windows
        tmux new-session -d -s "$session_name" -c "$project_path"
        tmux rename-window -t "$session_name:1" 'main'

        tmux new-window -t "$session_name:2" -n 'view' -c "$project_path"
        tmux send-keys -t "$session_name:2" 'lazygit' C-m
        tmux split-window -t "$session_name:2" -h -c "$project_path"
        tmux send-keys -t "$session_name:2" 'glow .' C-m

        tmux select-window -t "$session_name:1"
    fi

    # Attach or switch
    if [[ -n "$TMUX" ]]; then
        tmux switch-client -t "$session_name"
    else
        tmux attach-session -t "$session_name"
    fi
}

function create() {
    local lang="$1"
    local project_name="$2"

    # Interactive mode
    if [[ -z "$lang" ]]; then
        echo "Create projects for Github and different programming languages:"
        select lang in "Swift" "Java/Maven" "Rust/Cargo" "Crystal" "Git" "Cancel"; do
            [[ "$lang" == "Cancel" ]] && return 0
            [[ -n "$lang" ]] && break
        done
        read "project_name?Enter project name: "
    fi

    if [[ -z "$project_name" ]]; then
        echo "Error: Please provide a project name"
        echo "Usage: create <language> <project_name>"
        return 1
    fi

    case "$lang" in
        Swift|swift)
            mkdir -p "$project_name" && cd "$project_name"
            swift package init && git init ;;
        Java/Maven|Java|java|Maven|maven)
            mvn archetype:generate -DgroupId=com.example -DartifactId="$project_name" \
                -DarchetypeArtifactId=maven-archetype-quickstart -DinteractiveMode=false
            cd "$project_name" && git init ;;
        Rust/Cargo|Rust|rust|Cargo|cargo)
            cargo new "$project_name" && cd "$project_name" && git init ;;
        Crystal|crystal)
            crystal init app "$project_name" && cd "$project_name" && git init ;;
        Git|git)
            mkdir -p "$project_name" && cd "$project_name"
            git init && touch README.md ;;
        *)
            echo "Unknown language: $lang"
            echo "Supported: Swift, Java/Maven, Rust/Cargo, Crystal, Git"
            return 1 ;;
    esac

    mux-session "$project_name"
}

function attach() {
    if tmux list-sessions &>/dev/null; then
        local session
        session=$(tmux list-sessions | cut -d: -f1 | fzf)
        if [[ -n "$session" ]]; then
            if [[ -n "$TMUX" ]]; then
                tmux switch-client -t "$session"
            else
                tmux attach-session -t "$session"
            fi
        fi
    else
        echo "No tmux sessions found"
    fi
}

# --- functions:hooks ---
chpwd() {
    local current_dir="$PWD"
    local config_dir="${HOME}/.config"
    local dev_dir="${HOME}/development"

    if [[ "$current_dir" == "$config_dir" ]] || [[ "$current_dir" == "$dev_dir" ]]; then
        ls
    fi
}

# --- functions:UX ---
auto-cd-with-zoxide() {
  if [[ -n "$BUFFER" ]] && [[ "$BUFFER" != *" "* ]]; then
    if [[ "$BUFFER" == */* ]] || [[ "$BUFFER" == ~* ]]; then
      local dir="$BUFFER"
      BUFFER=""
      print -z "z $dir"
    fi
  fi
  zle accept-line
}

# --- functions:new functions ---
function duplicate() {
  if [ $# -eq 0 ]; then
    echo "Usage: duplicate <file_or_folder> [destination_name]"
    return 1
  fi

  local source="$1"
  local destination="$2"

  if [ ! -e "$source" ]; then
    echo "Error: '$source' does not exist"
    return 1
  fi

  if [ -z "$destination" ]; then
    local basename="${source%/}"
    local extension="${basename##*.}"
    local name="${basename%.*}"

    if [ "$basename" = "$extension" ]; then
      destination="${basename} copy"
    else
      destination="${name} copy.${extension}"
    fi
  fi

  cp -R "$source" "$destination"

  if [ $? -eq 0 ]; then
    echo "Duplicated '$source' to '$destination'"
  else
    echo "Error: Failed to duplicate '$source'"
    return 1
  fi
}

function download() { 
  if whence -q curl; then
    echo "Using curl to download: $1"
    curl -L -O "$1"
  elif whence -q wget; then
    echo "Using wget to download: $1"
    wget -c --show-progress "$1"
  else
    echo "Error: Neither curl nor wget is installed." >&2
    return 1
  fi
}

# --- functions:tmux-init ---
if [[ -n "$TMUX" ]] && [[ $(tmux display-message -p '#I') == "1" ]]; then
    local dir_name="$(basename "$PWD")"
    local current_session="$(tmux display-message -p '#S')"
    if [[ "$current_session" != "$dir_name" ]] && ! tmux has-session -t "$dir_name" 2>/dev/null; then
        tmux rename-session -t "$current_session" "$dir_name"
        tmux rename-window -t "$dir_name:1" 'main'
    fi
fi
