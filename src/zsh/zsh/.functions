#!/usr/bin/env zsh
# zsh functions
# Auther: CrtlUserUnknown
#
# to find the zsh config file look at ~/.zshrc
# to find the aliases look at ~/.config/zsh/.aliases

# --- functions:devUx ---
function commands() {
    if [[ "$1" == "costum" ]]; then
        echo "--- Aliases ---"
        echo "cls        clear the terminal"
        echo "ls         eza with color"
        echo "lla        eza all files with icons"
        echo "ll         eza list with icons"
        echo "reload     source ~/.zshrc"
        echo "open       open current directory"
        echo "y          yazi"
        echo "py         python3"
        echo "ipy        ipython3"
        echo "swiftinit  swift package init"
        echo "sps        swift package show-dependencies"
        echo "spt        swift package test"
        echo "jv         java"
        echo "jc         javac"
        echo "rn         rustc"
        echo "cr         cargo run"
        echo "mux        tmux"
        echo "b          btop"
        echo "f          fzf"
        echo ""
        echo "--- Functions ---"
        echo "commands     list commands or custom aliases/functions"
        echo "config     edit zsh, tmux, ghostty, or alias configs"
        echo "create     scaffold a new project (Swift, Java, Rust, Crystal, Git)"
        echo "attach     attach to a tmux session via fzf"
        echo "duplicate  duplicate a file or folder"
        echo "download   download a file using curl or wget"
    else
        echo $PATH | tr ':' '\n' | while read dir; do
            ls "$dir" 2>/dev/null
        done | sort -u | grep -v '/' | grep -v '@' | column -c $(tput cols)
        echo "\nTip: run 'commands custom' to see your custom aliases/functions"
    fi
}

function config() {
    if [[ -z "$1" ]]; then
        echo "Select configuration to edit:"
        select option in "Terminal/ZSH" "Tmux" "Ghostty" "Aliases" "Cancel"; do
            case "$option" in
                "Terminal/ZSH") ${EDITOR:-nvim} ~/development/dots/src/zsh/; break;;
                "Tmux") ${EDITOR:-nvim} ~/development/dots/src/tmux/tmux.conf; break;;
                "Ghostty") ${EDITOR:-nvim} ~/development/dots/src/ghostty/config; break;;
                "Aliases") ${EDITOR:-nvim} ~/development/dots/src/zsh/zsh/.aliases; break;;
                "Cancel") return 0;;
            esac
        done
    else
        case "$1" in
            terminal|zsh) ${EDITOR:-nvim} ~/development/dots/src/zsh/;;
            tmux|mux) ${EDITOR:-nvim} ~/development/dots/src/tmux/tmux.conf;;
            ghostty|ghost) ${EDITOR:-nvim} ~/development/dots/src/ghostty/config;;
            alias|aliases) ${EDITOR:-nvim} ~/development/dots/src/zsh/zsh/.aliases;;
            *) echo "Unknown config type: $1"; return 1;;
        esac
    fi
}

function create() {
    if [[ -z "$1" ]]; then
        echo "Create projects for Github and different programming languages:"
        select option in "Swift" "Java/Maven" "Rust/Cargo" "Crystal" "Git" "Cancel"; do
            case "$option" in
                "Swift") 
                    read "project_name?Enter project name: "
                    mkdir -p "$project_name" && cd "$project_name"
                    swift package init
                    git init
                    break;;
                "Java/Maven") 
                    read "project_name?Enter project name: "
                    mvn archetype:generate -DgroupId=com.example -DartifactId="$project_name" -DarchetypeArtifactId=maven-archetype-quickstart -DinteractiveMode=false
                    cd "$project_name"
                    git init
                    break;;
                "Rust/Cargo") 
                    read "project_name?Enter project name: "
                    cargo new "$project_name"
                    cd "$project_name"
                    git init
                    break;;
                "Crystal") 
                    read "project_name?Enter project name: "
                    crystal init app "$project_name"
                    cd "$project_name"
                    git init
                    break;;
                "Git")
                    read "project_name?Enter project name: "
                    mkdir -p "$project_name" && cd "$project_name"
                    git init
                    touch README.md
                    break;;
                "Cancel") return 0;;
            esac
        done
    else
        project_name="$2"
        if [[ -z "$project_name" ]]; then
            echo "Error: Please provide a project name"
            echo "Usage: create <language> <project_name>"
            return 1
        fi

        case "$1" in
            Swift|swift)
                mkdir -p "$project_name" && cd "$project_name"
                swift package init
                git init
                ;;
            Java|java|Maven|maven)
                mvn archetype:generate -DgroupId=com.example -DartifactId="$project_name" -DarchetypeArtifactId=maven-archetype-quickstart -DinteractiveMode=false
                cd "$project_name"
                git init
                ;;
            Rust|rust|Cargo|cargo)
                cargo new "$project_name"
                cd "$project_name"
                git init
                ;;
            Crystal|crystal)
                crystal init app "$project_name"
                cd "$project_name"
                git init
                ;;
            Git|git)
                mkdir -p "$project_name" && cd "$project_name"
                git init
                touch README.md
                ;;
            *) 
                echo "Unknown language: $1"
                echo "Supported languages: Swift, Java/Maven, Rust/Cargo, Crystal, Git"
                return 1
                ;;
        esac
    fi
}

function attach() {
    # Attach to an existing tmux session
    if tmux list-sessions &> /dev/null; then
        local session=$(tmux list-sessions | cut -d: -f1 | fzf)
        if [ -n "$session" ]; then
            tmux attach-session -t "$session"
        fi
    else
        echo "No tmux sessions found"
    fi
}

# --- functions:UX ---
auto-cd-with-zoxide() {
  if [[ -n "$BUFFER" ]] && [[ "$BUFFER" != *" "* ]]; then
    # Check if buffer looks like a path (contains / or ~)
    if [[ "$BUFFER" == */* ]] || [[ "$BUFFER" == ~* ]]; then
      local dir="$BUFFER"
      BUFFER=""
      print -z "z $dir"
    fi
  fi
  zle accept-line
}

# --- functions:new functions ---
function duplicate() {
  if [ $# -eq 0 ]; then
    echo "Usage: duplicate <file_or_folder> [destination_name]"
    return 1
  fi

  local source="$1"
  local destination="$2"

  if [ ! -e "$source" ]; then
    echo "Error: '$source' does not exist"
    return 1
  fi

  # If no destination provided, create one with " copy" suffix
  if [ -z "$destination" ]; then
    local basename="${source%/}"
    local extension="${basename##*.}"
    local name="${basename%.*}"

    # Check if file has an extension
    if [ "$basename" = "$extension" ]; then
      destination="${basename} copy"
    else
      destination="${name} copy.${extension}"
    fi
  fi

  # Use cp with -R flag for recursive copying (works for both files and folders)
  cp -R "$source" "$destination"

  if [ $? -eq 0 ]; then
    echo "Duplicated '$source' to '$destination'"
  else
    echo "Error: Failed to duplicate '$source'"
    return 1
  fi
}

 function download() { 
  # Check if curl is available using Zsh's 'whence'
  if whence -q curl; then
    echo "Using curl to download: $1"
    # -L: Follow redirects, -O: Write output to a local file
    curl -L -O "$1"

  # Check if wget is available
  elif whence -q wget; then
    echo "Using wget to download: $1"
    # -c: Continue download, --show-progress: Display progress
    wget -c --show-progress "$1"

  # Neither is found
  else
    echo "Error: Neither curl nor wget is installed." >&2
    return 1
  fi
}

