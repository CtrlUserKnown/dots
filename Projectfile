#!/usr/bin/env bash

# tmux session creator for project

# this script will start a tmux session with for every i come back to this project
SESSIONNAME="Dotfiles"
PROJECTPATH="."

# check if tmux is installed
command -v tmux >/dev/null 2>&1 || { echo "Error: tmux is not installed"; exit 1; }

# check if project directory exists
if [ ! -d "$PROJECTPATH" ]; then
    echo "Error: Project directory $PROJECTPATH does not exist"
    exit 1
fi

# check if the tmux session already exists
# if it does, attach to it and exists
# if tmux does not exists, create it and start the project from the place you left off
tmux has-session -t $SESSIONNAME 2>/dev/null
if [ $? != 0 ]; then
    # create a new tmux session
    tmux new-session -d -s $SESSIONNAME -c $PROJECTPATH

    # create a window for editing code
    tmux rename-window -t $SESSIONNAME:0 'editor'
    tmux send-keys -t $SESSIONNAME:0 'nvim .' C-m

    # create a window for running tests
    tmux new-window -t $SESSIONNAME:1 -n 'tests' -c $PROJECTPATH
    tmux send-keys -t $SESSIONNAME:1 'clear' C-m

    # create a window for documentation
    tmux new-window -t $SESSIONNAME:2 -n 'docs' -c $PROJECTPATH
    tmux send-keys -t $SESSIONNAME:2 'clear' C-m

    # create a window for git operations
    tmux new-window -t $SESSIONNAME:3 -n 'git' -c $PROJECTPATH
    tmux send-keys -t $SESSIONNAME:3 'clear' C-m

    # create a window for gemini-cli
    tmux new-window -t $SESSIONNAME:4 -n 'container' -c $PROJECTPATH
    tmux send-keys -t $SESSIONNAME:4 'clear' C-m

fi

# attach to the session
tmux attach-session -t $SESSIONNAME
